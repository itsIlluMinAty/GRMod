<root>
    <styles>
        <include src="file://{resources}/styles/gamestyles.css" />
        <include src="file://{resources}/styles/popups/popups_shared.css" />
        <include src="file://{resources}/styles/popups/popup_info.css" />
    </styles>

    <PopupCustomLayout class="PopupPanel popup-info-notice Hidden"
        defaultfocus="PopupInfoBody"
        popupbackground="dim"
        oncancel="UIPopupButtonClicked();">

        <Panel class="popup-info-notice__header">
            <Label class="popup-info-notice__title" text="Frequently Asked Questions" />
        </Panel>

        <Panel id="PopupInfoBody" class="popup-info-notice__body" hittest="true" acceptsfocus="true">
            <Panel class="popup-info-notice__faq top-bottom-flow">
                <Panel class="popup-info-notice__section top-bottom-flow">
                    <Label class="popup-info-notice__section-title" text="What Is GCMM?" />
                    <Label class="popup-info-notice__message"
                        html="true"
                        text="GCMM is a fork of csgo_gc that brings back the ability to matchmake inside CSGO while allowing official GCMM servers and community servers." />
                </Panel>

                <Panel class="popup-info-notice__section-divider" />

                <Panel class="popup-info-notice__section top-bottom-flow">
                    <Label class="popup-info-notice__section-title" text="How can my server be found by GCMM?" />
                    <Label class="popup-info-notice__message"
                        html="true"
                        text="It's easy! Just use the same csgo_gc dll that GCMM uses and change &quot;gcmm_enroll&quot; to &quot;1&quot;." />
                </Panel>

                <Panel class="popup-info-notice__section-divider" />

                <Panel class="popup-info-notice__section top-bottom-flow">
                    <Label class="popup-info-notice__section-title" text="I've disconnected from a competitive match and I don't see the reconnect option! What do I do?" />
                    <Label class="popup-info-notice__message"
                        html="true"
                        text="Queue up for any mode in matchmaking and it will automatically reconnect you to the match." />
                </Panel>

                <Panel class="popup-info-notice__section-divider" />

                <Panel class="popup-info-notice__section top-bottom-flow">
                    <Label class="popup-info-notice__section-title" text="When I queue it instantly cancels? Why is this happening?" />
                    <Label class="popup-info-notice__message"
                        html="true"
                        text="Your GCMM version might be outdated. Please update to the latest version." />
                </Panel>

                <Panel class="popup-info-notice__section-divider" />

                <Panel class="popup-info-notice__section top-bottom-flow">
                    <Label class="popup-info-notice__section-title" text="Are cooldowns still enforced?" />
                    <Label class="popup-info-notice__message"
                        html="true"
                        text="Since we are a small community, cooldowns are not enforced as that would limit the number of available players. However, cooldowns can still be applied for players who are actively griefing and ruining the experience for others." />
                </Panel>

                <Panel class="popup-info-notice__section-divider" />

                <Panel class="popup-info-notice__section top-bottom-flow">
                    <Label class="popup-info-notice__section-title" text="Why is some text in English and not in my native language?" />
                    <Label class="popup-info-notice__message"
                        html="true"
                        text="Translation reasons. For one I don't want to manually go through every string and translate it, and second I don't want to rely on things like Google Translate because it can be inaccurate." />
                </Panel>

                <Panel class="popup-info-notice__section-divider" />

                <Panel class="popup-info-notice__section top-bottom-flow">
                    <Label class="popup-info-notice__section-title" text="How do I report abuse?" />
                    <Label class="popup-info-notice__message"
                        html="true"
                        text="If someone is cheating/exploting on official servers send a report on the discord. If the player is on a community server found by GCMM, report it to us under matchmaking abuse and also send a report to the server admin." />
                </Panel>

            </Panel>
        </Panel>

        <Panel class="PopupButtonRow popup-info-notice__buttons">
            <TextButton id="PopupInfoDiscord"
                class="PopupButton popup-info-notice__button popup-info-notice__button-spaced"
                text="Discord"
                onactivate="SteamOverlayAPI.OpenUrlInOverlayOrExternalBrowser( 'https://discord.gg/szH9FBbeNv' );" />
            <TextButton id="PopupInfoOk"
                class="PopupButton popup-info-notice__button"
                text="Close"
                onactivate="UIPopupButtonClicked();" />
        </Panel>
    </PopupCustomLayout>
</root>
